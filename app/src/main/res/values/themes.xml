<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="Theme.ManfaatTumbuhan" parent="Theme.Material3.Light">
        <item name="colorPrimary">@color/green_primary</item>
        <item name="colorPrimaryDark">@color/green_dark</item>
        <item name="colorAccent">@color/green_primary</item>
        <item name="android:statusBarColor">@color/green_dark</item>
        <item name="android:navigationBarColor">@color/green_primary</item>
        <item name="android:navigationBarDividerColor">@color/transparent</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:windowLightNavigationBar">false</item>
