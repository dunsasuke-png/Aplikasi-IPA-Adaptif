<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white">

    <!-- Main Quiz Content -->
    <!-- Main Quiz Content -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/layoutQuizContent"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/gray_bg"
        android:visibility="gone">

        <!-- Top Header Background -->
        <View
            android:id="@+id/quizHeaderBg"
            android:layout_width="match_parent"
            android:layout_height="140dp"
            android:background="@drawable/bg_header_curved"
            app:layout_constraintTop_toTopOf="parent" />

        <!-- Top Bar -->
        <LinearLayout
            android:id="@+id/quizTopBar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingHorizontal="16dp"
            android:paddingTop="16dp"
            app:layout_constraintTop_toTopOf="parent">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_circle_white"
                android:paddingHorizontal="12dp"
                android:paddingVertical="4dp"
                android:gravity="center">

                <TextView
                    android:id="@+id/tvTingkatLabel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/tingkat_soal_label"
                    android:textColor="@color/green_dark"
                    android:textSize="12sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <View
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:layout_weight="1" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="⏱️ "
                    android:textSize="14sp" />
                <TextView
                    android:id="@+id/tvTimer"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/latihan_timer_default"
                    android:textColor="@color/white"
                    android:textSize="16sp"
                    android:textStyle="bold" />
            </LinearLayout>
        </LinearLayout>

        <!-- Progress Area -->
        <LinearLayout
            android:id="@+id/quizProgressArea"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="16dp"
            android:paddingTop="8dp"
            app:layout_constraintTop_toBottomOf="@+id/quizTopBar">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">
                <TextView
                    android:id="@+id/tvSoalCounter"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/latihan_soal_counter_default"
                    android:textColor="#E0F2F1"
                    android:textSize="12sp" />

                <View
                    android:layout_width="0dp"
                    android:layout_height="0dp"
                    android:layout_weight="1" />

                <TextView
                    android:id="@+id/tvProgress"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/latihan_progress_default"
                    android:textColor="@color/white"
                    android:textSize="12sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <ProgressBar
                android:id="@+id/progressBar"
                style="?android:attr/progressBarStyleHorizontal"
                android:layout_width="match_parent"
                android:layout_height="6dp"
                android:layout_marginTop="4dp"
                android:max="100"
                android:progress="0"
                android:progressTint="@color/white"
                android:progressBackgroundTint="#4DFFFFFF" />
        </LinearLayout>

        <!-- Main Card Question -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardQuestion"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_marginHorizontal="12dp"
            android:layout_marginTop="12dp"
            android:layout_marginBottom="8dp"
            app:cardBackgroundColor="@color/white"
            app:cardCornerRadius="20dp"
            app:cardElevation="6dp"
            app:layout_constraintTop_toBottomOf="@+id/quizProgressArea"
            app:layout_constraintBottom_toTopOf="@+id/quizBottomBar">

            <ScrollView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:fillViewport="true">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <ImageView
                        android:id="@+id/imgSoal"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:adjustViewBounds="true"
                        android:maxHeight="200dp"
                        android:layout_marginTop="16dp"
                        android:background="@drawable/bg_border_image"
                        android:scaleType="fitCenter"
                        android:visibility="gone"
                        android:contentDescription="@string/latihan_soal_image_desc"
                        android:importantForAccessibility="no" />

                    <FrameLayout
                        android:id="@+id/videoContainer"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:visibility="gone">

                        <com.google.android.material.card.MaterialCardView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginHorizontal="12dp"
                            app:cardCornerRadius="16dp"
                            app:cardElevation="2dp">

                            <androidx.media3.ui.PlayerView
                                android:id="@+id/videoPlayerInline"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:minHeight="180dp"
                                app:resize_mode="fit"
                                app:show_buffering="when_playing"
                                app:use_controller="true" />
                        </com.google.android.material.card.MaterialCardView>
                    </FrameLayout>

                    <TextView
                        android:id="@+id/tvPertanyaan"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="@string/latihan_pertanyaan_default"
                        android:textColor="@color/green_dark"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:lineSpacingExtra="2dp" />

                    <RadioGroup
                        android:id="@+id/radioGroup"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp" />
                </LinearLayout>
            </ScrollView>
        </com.google.android.material.card.MaterialCardView>

        <!-- Bottom Bar Buttons -->
        <LinearLayout
            android:id="@+id/quizBottomBar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingHorizontal="16dp"
            android:paddingVertical="12dp"
            android:background="@color/white"
            android:elevation="16dp"
            app:layout_constraintBottom_toBottomOf="parent">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnKembali"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_marginEnd="8dp"
                android:layout_weight="1"
                android:text="@string/latihan_btn_kembali"
                android:textColor="@color/green_primary"
                app:cornerRadius="12dp"
                app:strokeColor="@color/green_primary" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnSelanjutnya"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_marginStart="8dp"
                android:layout_weight="1"
                android:text="@string/latihan_btn_selanjutnya"
                android:textSize="14sp"
                app:backgroundTint="@color/green_primary"
                app:cornerRadius="12dp" />
        </LinearLayout>
    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- Start Overlay -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/layoutStartOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/gray_bg">

        <View
            android:layout_width="match_parent"
            android:layout_height="240dp"
            android:background="@drawable/bg_header_curved"
            app:layout_constraintTop_toTopOf="parent" />

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="24dp"
            app:cardBackgroundColor="@color/white"
            app:cardCornerRadius="24dp"
            app:cardElevation="12dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:orientation="vertical"
                android:padding="32dp">

                <ImageView
                    android:layout_width="80dp"
                    android:layout_height="80dp"
                    android:background="@drawable/bg_circle_green_light"
                    android:padding="16dp"
                    android:src="@drawable/ic_quiz"
                    app:tint="@color/green_primary"
                    android:contentDescription="@string/latihan_quiz_icon_desc"
                    android:importantForAccessibility="no" />

                <TextView
                    android:id="@+id/tvStartTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="24dp"
                    android:text="Siap Mengerjakan? 🚀"
                    android:textColor="@color/green_dark"
                    android:textSize="24sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvStartDesc"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:gravity="center"
                    android:text="@string/latihan_start_desc"
                    android:textColor="@color/gray_text"
                    android:textSize="14sp" />

                <LinearLayout
                    android:id="@+id/layoutStartInfo"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="24dp"
                    android:background="@drawable/bg_rounded_gray"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:id="@+id/tvStartTingkat"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/latihan_start_tingkat_default"
                        android:textColor="@color/green_dark"
                        android:textSize="14sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="🎯 Maksimal 20 soal pilihan ganda"
                        android:textColor="@color/gray_text"
                        android:textSize="13sp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="⏳ Waktu dicatat untuk analisis kemampuanmu"
                        android:textColor="@color/gray_text"
                        android:textSize="13sp" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="32dp"
                    android:orientation="horizontal">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnBelumSiap"
                        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                        android:layout_width="0dp"
                        android:layout_height="56dp"
                        android:layout_marginEnd="8dp"
                        android:layout_weight="1"
                        android:text="Kembali 🔙"
                        android:textColor="@color/green_primary"
                        app:cornerRadius="16dp"
                        app:strokeColor="@color/green_primary" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnMulai"
                        android:layout_width="0dp"
                        android:layout_height="56dp"
                        android:layout_marginStart="8dp"
                        android:layout_weight="1"
                        android:text="Mulai ✨"
                        android:textSize="16sp"
                        app:backgroundTint="@color/green_primary"
                        app:cornerRadius="16dp" />
                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>
    </androidx.constraintlayout.widget.ConstraintLayout>

</FrameLayout>
